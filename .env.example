PORT=4501
NODE_ENV=development

# Firebase Admin SDK service account (download from Firebase Console > Project Settings > Service accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Image generation (test admin page) ---
# Required by the admin-only /api/carkedit/image-gen/* routes. Each provider
# is gated on its key being present; missing keys cause the UI to grey out
# the corresponding dropdown entry.
#
# Leonardo.AI (Phoenix 1.0 model):
#   https://cloud.leonardo.ai/api-access
LEONARDO_API_KEY=

# Black Forest Labs (FLUX 2 Pro — falls back to flux-pro-1.1 until 2.0 ships):
#   https://docs.bfl.ai/quick_start/create_account
FLUX_API_KEY=
# Optional override for the BFL model slug (e.g. "flux-pro-2.0" once released).
# FLUX_MODEL_SLUG=flux-pro-1.1
